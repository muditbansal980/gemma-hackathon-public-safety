# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=public_safety
POSTGRES_HOST=localhost
POSTGRES_PORT=5440

# SQLAlchemy (psycopg3 driver)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5440/public_safety

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_VIDEO_QUEUE=video_queue
REDIS_ALERT_CHANNEL=alerts
REDIS_EVENTS_CHANNEL=events

# Recording
RECORDINGS_DIR=data/recordings
CHUNK_DURATION_SECONDS=60
DEFAULT_WEBCAM_INDEX=0
DEFAULT_FPS=20

# CORS (Next.js dev server)
CORS_ORIGINS=["http://localhost:3000"]
