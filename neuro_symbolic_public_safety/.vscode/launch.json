{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Pipeline (main.py)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": [
        "--video", "${workspaceFolder}/data/security_footage.mp4",
        "--output-dir", "${workspaceFolder}/output"
      ],
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Zone Calibrator (interactive)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tools/zone_calibrator.py",
      "args": [
        "--video", "${workspaceFolder}/data/security_footage.mp4",
        "--zone-name", "Restricted_Zone_Alpha"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
